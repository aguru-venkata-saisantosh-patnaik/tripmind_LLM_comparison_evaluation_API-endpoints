# TripMind — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# ── Required for Phase 1 & 2 ─────────────────────────────────────────────────
# Google AI Studio (free): https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Required for Phase 2 (MCP Servers) ───────────────────────────────────────
# OpenRouteService (free, no credit card): https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# Amadeus for Developers (free sandbox, no credit card): https://developers.amadeus.com/register
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Tavily Search (free 1k/month, no credit card): https://app.tavily.com
# Optional — DuckDuckGo library is the primary and needs no key
TAVILY_API_KEY=

# Brave Search API (free 2k/month, no credit card): https://api.search.brave.com/register
# Optional fallback if DuckDuckGo results are thin
BRAVE_SEARCH_API_KEY=

# ── Required for Phase 4 (Eval Judge) ────────────────────────────────────────
# Groq API (free tier, no credit card): https://console.groq.com/keys
GROQ_API_KEY=

# ── Optional: HuggingFace (for Phase 3 model upload) ─────────────────────────
# HuggingFace Hub (free for public repos): https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Database ─────────────────────────────────────────────────────────────────
# Default ClickHouse local Docker instance — change only if using ClickHouse Cloud
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=tripmind
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
